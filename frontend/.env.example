# Variables d'environnement Vite pour ESPACE-PRIVATIF (frontend).
#
# En LOCAL (dev) : laisser ces deux variables vides.
#   - les appels API partent en /api et sont proxifies par Vite vers
#     http://web:80 (cf. vite.config.ts).
#
# En PROD (Vercel) : pointer explicitement vers les services Render.

# URL publique de l'API Slim (sans slash final, sans suffixe /api).
# Exemple : https://espace-privatif-api.onrender.com
VITE_API_BASE_URL=

# URL publique du serveur WebSocket Ratchet.
# Exemple : wss://espace-privatif-ws.onrender.com
VITE_WS_URL=
