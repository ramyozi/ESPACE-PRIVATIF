{
    "name": "realsoft/espace-privatif",
    "description": "Module de signature electronique pour ESPACE-PRIVATIF",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5",
        "symfony/mailer": "^6.4",
        "twig/twig": "^3.8",
        "slim/twig-view": "^3.3",
        "ramsey/uuid": "^4.7",
        "cboden/ratchet": "^0.4.4",
        "respect/validation": "^2.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:8080 -t public",
        "ws": "php bin/ws-server.php",
        "test": "phpunit",
        "lint": "phpcs --standard=PSR12 app/"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
