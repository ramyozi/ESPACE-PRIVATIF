# =============================================================================
# Environnement
# =============================================================================
# IMPORTANT : avec APP_ENV=dev, le code OTP "123456" est accepte par le service
# de signature (raccourci de developpement). En production, mettre APP_ENV=prod.
APP_ENV=dev
APP_DEBUG=true
APP_URL=http://localhost:8080

# =============================================================================
# Base de donnees
# =============================================================================
# Drivers supportes : "mysql" (local Docker) ou "pgsql" (Supabase / cloud).
DB_DRIVER=mysql

# --- Local (Docker Compose, MySQL 8) ---
DB_HOST=db
DB_PORT=3306
DB_NAME=espace_privatif
DB_USER=app
DB_PASSWORD=app_secret
DB_ROOT_PASSWORD=root_secret

# --- Cloud (Supabase PostgreSQL) ---
# Remplacer les valeurs ci-dessus par celles fournies par Supabase :
#   DB_DRIVER=pgsql
#   DB_HOST=aws-X-eu-central-1.pooler.supabase.com  (ou db.<ref>.supabase.co)
#   DB_PORT=6543                                     (pooler) ou 5432
#   DB_NAME=postgres
#   DB_USER=postgres.<project-ref>
#   DB_PASSWORD=<supabase password>
#   DB_SSLMODE=require

# =============================================================================
# Mail
# =============================================================================
# Envoi via Resend (https://resend.com).
# - Vide en local : pas d'envoi reel, on se contente d'empiler en mail_queue.
# - En prod : recuperer une cle dans le dashboard Resend.
RESEND_API_KEY=

# Sender configure cote DNS (DKIM/SPF/DMARC) pour realsoft.espace.privatif.
MAIL_FROM=no-reply@realsoft.espace.privatif
MAIL_FROM_NAME="Espace Privatif"

# =============================================================================
# Securite
# =============================================================================
APP_SECRET=change-me-in-production-please
SESSION_LIFETIME=7200

# CORS : origines autorisees a appeler l'API (separees par virgule).
# Indispensable lorsque le frontend est servi depuis un autre domaine
# (Vercel, Cloudflare Pages, etc.). Laisse vide en local.
# Exemple : CORS_ALLOWED_ORIGINS=https://espace-privatif.vercel.app
CORS_ALLOWED_ORIGINS=

# =============================================================================
# WebSocket
# =============================================================================
WS_HOST=0.0.0.0
WS_PORT=8081
WS_TOKEN_SECRET=change-me-ws-secret

# URL publique du serveur WS, utilisee par le frontend pour se connecter.
# - local : ws://localhost:8081
# - prod  : wss://<service-ws>.onrender.com
WS_PUBLIC_URL=ws://localhost:8081

# =============================================================================
# SOTHIS
# =============================================================================
SOTHIS_CALLBACK_URL=http://sothis-mock:9000/callback
SOTHIS_API_KEY=sothis-shared-key-dev

# =============================================================================
# OTP
# =============================================================================
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
