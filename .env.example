# Environnement
APP_ENV=dev
APP_DEBUG=true
APP_URL=http://localhost:8080

# Base de donnees
DB_HOST=db
DB_PORT=3306
DB_NAME=espace_privatif
DB_USER=app
DB_PASSWORD=app_secret
DB_ROOT_PASSWORD=root_secret

# Mail (transport "log" en dev, ecrit dans var/log/mail.log)
MAIL_DSN=null://null
MAIL_FROM=no-reply@espace-privatif.local
MAIL_FROM_NAME="Espace Privatif"

# Securite
APP_SECRET=change-me-in-production-please
SESSION_LIFETIME=7200

# WebSocket
WS_HOST=0.0.0.0
WS_PORT=8081
WS_TOKEN_SECRET=change-me-ws-secret

# SOTHIS
SOTHIS_CALLBACK_URL=http://sothis-mock:9000/callback
SOTHIS_API_KEY=sothis-shared-key-dev

# OTP
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
